{
  "name": "subscription-renewal",
  "version": "1.0.0",
  "description": "Subscription renewal service with CI/CD",
  "main": "server.js",
  "scripts": {
    "test": "jest",
    "test:unit": "jest --config=jest.config.allure.js",
    "test:api": "cucumber-js --format json:allure-results/cucumber.json",
    "test:ui": "npx playwright test --reporter=line,allure-playwright",
    "test:ui:headed": "npx playwright test --headed --reporter=line,allure-playwright",
    "test:ui:debug": "npx playwright test --debug",
    "test:ui:report": "npx playwright show-report",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "kill": "taskkill /F /IM node.exe 2>nul || echo No node process found"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@cucumber/cucumber": "^11.3.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "allure-jest": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "wait-on": "^9.0.5"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
