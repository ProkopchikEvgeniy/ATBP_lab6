{
  "name": "subscription-renewal",
  "version": "1.0.0",
  "description": "Subscription renewal service with CI/CD",
  "main": "server.js",
  "scripts": {
  "test": "jest",
  "test:unit": "jest",
  "test:api": "cucumber-js --require steps/**/*.js features/**/*.feature",
