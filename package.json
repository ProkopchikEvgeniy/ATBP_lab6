    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "allure-jest": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "wait-on": "^9.0.5"
  },
